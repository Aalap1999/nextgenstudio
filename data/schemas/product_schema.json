{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ProductSchema",
  "type": "object",
  "required": ["products"],
  "properties": {
    "products": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "name",
          "category",
          "default_cleanroom_requirement",
          "typical_parts_list",
          "base_operations"
        ],
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "category": { "type": "string" },
          "default_cleanroom_requirement": { "type": "boolean" },
          "typical_parts_list": {
            "type": "array",
            "items": { "type": "string" }
          },
          "base_operations": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["step", "operation_type", "required"],
              "properties": {
                "step": { "type": "integer", "minimum": 1 },
                "operation_type": { "type": "string" },
                "required": { "type": "boolean" },
                "notes": { "type": "string" }
              }
            }
          }
        }
      }
    }
  }
}
